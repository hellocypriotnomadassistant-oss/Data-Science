gizli_sayi = 7  # Bilgisayarın tuttuğu sayı
tahmin_sayisi = 0

print("--- Sayı Tahmin Oyununa Hoş Geldin! ---")
print("1 ile 10 arasında bir sayı tuttum. Tahmin et bakalım.")

while True:
    tahmin = int(input("Tahminin nedir?: "))
    tahmin_sayisi += 1

    if tahmin < 0:
        print("Lütfen negatif sayı girmeyin!")
        continue  # Negatif girilirse bu turu sayma, başa dön

    if tahmin < gizli_sayi:
        print("Daha YÜKSEK bir sayı söyle...")
    elif tahmin > gizli_sayi:
        print("Daha DÜŞÜK bir sayı söyle...")
    else:
        print(f"TEBRİKLER! {tahmin_sayisi} denemede doğru bildin.")
        break  # Doğru bildiğinde döngüden çık
